{
  "rules": {
    "rooms": {
      "$roomCode": {
        // Qualquer usuário autenticado pode ler a sala
        ".read": "auth != null",

        "config": {
          // Qualquer autenticado pode ler/escrever config
          ".write": "auth != null"
        },

        "players": {
          // Qualquer autenticado pode ler jogadores
          "$uid": {
            // Jogador só pode escrever no próprio nó, ou host pode remover
            ".write": "auth != null && ($uid === auth.uid || data.parent().parent().child('config/hostId').val() === auth.uid)"
          }
        },

        "game": {
          ".write": "auth != null"
        },

        "history": {
          ".write": "auth != null"
        },

        "winners": {
          ".write": "auth != null"
        }
      }
    }
  }
}
